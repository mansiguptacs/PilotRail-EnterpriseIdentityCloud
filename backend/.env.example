# Required for Terraform generation + Grok AI policy review + developer coach
XAI_API_KEY=your-xai-api-key-here

# Grok model (default: grok-3-mini — fast and cost-effective for policy review)
# XAI_MODEL=grok-3-mini

# Run Grok policy review on terraform apply (wrapper) submissions (default: true)
PILOT_AI_ON_APPLY=true
